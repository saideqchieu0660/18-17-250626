generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VibeApiKey {
  id            String    @id @default(uuid())
  keyValue      String    @unique
  status        String    @default("GREEN") // GREEN, ORANGE, RED
  recoveryUntil DateTime?
}
